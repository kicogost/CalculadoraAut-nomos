# Required ONLY for the AI document reader (Lector → "Escanear con IA").
# Set this in your Vercel project (Settings → Environment Variables), not in the client.
# The key stays server-side; the browser never sees it.
ANTHROPIC_API_KEY=sk-ant-...

# Optional: override the extraction model. Defaults to claude-haiku-4-5
# (cost-effective for document extraction). For harder documents you can use a
# stronger model, e.g.:
# EXTRACT_MODEL=claude-sonnet-4-6
# EXTRACT_MODEL=claude-opus-4-8
